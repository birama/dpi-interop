// Prisma Schema - Questionnaire Interopérabilité SENUM
// Generated: 2026-03-06

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTIFICATION
// ============================================================================

model User {
  id                 String  @id @default(uuid())
  email              String  @unique
  password           String // bcrypt hashed
  role               Role    @default(INSTITUTION)
  mustChangePassword Boolean @default(true)

  // Relations
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])

  // PTF (module Partenaires Techniques et Financiers — phase 1)
  ptfId          String?
  ptf            PTF?      @relation(fields: [ptfId], references: [id])
  cguAccepteesAt DateTime?

  // Organisation (AMO/prestataires — role PARTENAIRE_TECHNIQUE)
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])

  // Audit
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Sessions
  sessions UserSession[]

  // Vue 360° — relations inverses
  stakeholdersAjoutes   UseCaseStakeholder[]   @relation("StakeholderAjoute")
  stakeholdersRetires   UseCaseStakeholder[]   @relation("StakeholderRetire")
  consultationsOuvertes UseCaseConsultation[]  @relation("ConsultationOuvertePar")
  feedbacksAuteur       UseCaseFeedback[]      @relation("FeedbackAuteur")
  statusHistoryAuteur   UseCaseStatusHistory[] @relation("StatusHistoryAuteur")
  notificationsVue360   Notification[]         @relation("UserNotifications")
  registresUsageAjoutes CasUsageRegistre[]     @relation("RegistreUsageAjoute")

  // Catalogue propositions (P8)
  adoptionsEffectuees     CasUsageMVP[]      @relation("CasUsageAdoptePar")
  adoptionRequestsDemande AdoptionRequest[]  @relation("AdoptionRequestDemandeur")
  adoptionRequestsTraite  AdoptionRequest[]  @relation("AdoptionRequestValideur")
  relationsCasUsageCrees  RelationCasUsage[] @relation("RelationCasUsageCree")

  // PTF Phase 2 — relations inverses
  manifestationsCreees   ManifestationInteret[] @relation("ManifestationCreator")
  manifestationsValidees ManifestationInteret[] @relation("ValidateurManifestation")
  auditEventsPtf         JournalAuditPtf[]      @relation("AuditUserPtf")

  @@index([email])
  @@index([ptfId])
  @@map("users")
}

enum Role {
  ADMIN
  INSTITUTION
  BAILLEUR
  PARTENAIRE_TECHNIQUE // AMO, prestataires d'accompagnement (ex: Accenture)
}

enum OrganisationType {
  CABINET_CONSEIL
  INTEGRATEUR
  EDITEUR
  EXPERT_INDEPENDANT
}

enum OrganisationStatus {
  ACTIF
  INACTIF
  ARCHIVE
}

model Organisation {
  id                    String             @id // code (ex: ACCENTURE)
  nom                   String
  type                  OrganisationType
  secteurAccompagnement String?            @db.Text
  dateRattachement      DateTime?
  dateFinPrevue         DateTime?
  statut                OrganisationStatus @default(ACTIF)
  users                 User[]
  accompagnements       AccompagnementAMO[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organisations")
}

// ============================================================================
// ACCOMPAGNEMENT AMO — ÉNUMÉRATIONS ET MODÈLES (P14-CONC)
// ============================================================================

enum TypeAccompagnement {
  ROADMAP_V0
  ROADMAP_V1
  IMPLEMENTATION
  AUDIT
  STANDARDISATION
  FORMATION
  AUTRE
}

enum StatutAccompagnement {
  ACTIF
  SUSPENDU
  TERMINE
}

enum TypeJalon {
  DIAGNOSTIC
  CADRAGE
  POC
  IMPLEMENTATION
  RECETTE
  MISE_EN_PRODUCTION
  AUDIT_QUALITE
  AUTRE
}

enum StatutJalon {
  PLANIFIE
  EN_COURS
  REALISE
  REPORTE
  ANNULE
}

enum VisibiliteCommentaire {
  DU_ET_AMO
  DU_ONLY
  AMO_ONLY
}

/// Accompagnement AMO d'un cas d'usage par une organisation (cabinet conseil, intégrateur)
/// N-N Organisation ↔ CasUsageMVP avec payload de suivi
model AccompagnementAMO {
  id              String               @id @default(uuid())
  organisationId  String
  organisation    Organisation         @relation(fields: [organisationId], references: [id])
  casUsageMVPId   String
  casUsageMVP     CasUsageMVP          @relation(fields: [casUsageMVPId], references: [id], onDelete: Cascade)

  type            TypeAccompagnement
  statut          StatutAccompagnement @default(ACTIF)
  scoreMaturite   Int?                 @db.SmallInt
  description     String?              @db.Text
  dateDebut       DateTime?
  dateFinPrevue   DateTime?
  dateFinEffective DateTime?

  jalons      JalonAccompagnement[]
  commentaires CommentaireAMO[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, casUsageMVPId])
  @@index([organisationId])
  @@index([casUsageMVPId])
  @@index([statut])
  @@map("accompagnement_amo")
}

/// Jalon d'un accompagnement AMO (feuille de route)
model JalonAccompagnement {
  id                String              @id @default(uuid())
  accompagnementId  String
  accompagnement    AccompagnementAMO   @relation(fields: [accompagnementId], references: [id], onDelete: Cascade)

  type        TypeJalon
  libelle     String
  description String?             @db.Text
  trimestre   String?             // ex: "Q3 2026"
  statut      StatutJalon         @default(PLANIFIE)
  ordre       Int                 @default(0)
  datePrevue  DateTime?
  dateReelle  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accompagnementId])
  @@index([statut])
  @@index([trimestre])
  @@map("jalon_accompagnement")
}

/// Commentaire interne dans le cadre d'un accompagnement AMO
model CommentaireAMO {
  id                String              @id @default(uuid())
  accompagnementId  String
  accompagnement    AccompagnementAMO   @relation(fields: [accompagnementId], references: [id], onDelete: Cascade)

  contenu     String                  @db.Text
  visibilite  VisibiliteCommentaire   @default(DU_ET_AMO)
  createdBy   String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([accompagnementId])
  @@index([createdAt])
  @@map("commentaire_amo")
}

// ============================================================================
// VUE 360° — ÉNUMÉRATIONS
// ============================================================================

/// Rôle joué par une institution dans un cas d'usage
enum UseCaseRole {
  INITIATEUR
  FOURNISSEUR
  CONSOMMATEUR
  PARTIE_PRENANTE
}

/// Statut du cas d'usage dans le pipeline Vue 360°
/// PROPOSE : amont du pipeline (catalogue des propositions P8)
/// ARCHIVE / FUSIONNE : sortie de catalogue par decision DU (P8)
enum UseCaseStatus {
  PROPOSE // P8 : inscrit au catalogue, pas encore adopte par une institution
  DECLARE
  EN_CONSULTATION
  VALIDATION_CONJOINTE
  QUALIFIE
  PRIORISE
  FINANCEMENT_OK
  CONVENTIONNE
  EN_PRODUCTION_360 // suffixé pour éviter conflit avec StatutImplementation.EN_PRODUCTION
  SUSPENDU_360 // suffixé pour éviter conflit avec StatutImplementation.SUSPENDU
  RETIRE
  ARCHIVE // P8 : proposition archivee par la DU (non adoptee, non pertinente)
  FUSIONNE // P8 : proposition fusionnee avec un autre cas d'usage
}

/// Typologie du cas d'usage (P9)
/// METIER   : parcours multi-administrations oriente beneficiaire, porte par un coordonnateur
/// TECHNIQUE : echange bilateral oriente systeme, porte par le detenteur de donnee
enum TypologieCasUsage {
  METIER
  TECHNIQUE
}

/// Source d'une proposition (P8) — origine institutionnelle de la proposition
enum SourceProposition {
  ATELIER_CADRAGE // Atelier dedie (ateliers de conception, matinees)
  ETUDE_SENUM // Etude interne SENUM SA
  RECOMMANDATION // Recommandation d'une autorite (CDP, ARTP, etc.)
  CADRAGE_STRATEGIQUE // Cadrage PRES, Vision Senegal 2050, etc.
  PROPOSITION_INSTITUTIONNELLE // Proposition soumise par une administration
  BAILLEUR // PTF Phase 2 : proposition issue d'un Partenaire Technique et Financier
}

/// PTF Phase 2 — Référentiel normalisé des domaines d'interopérabilité
/// Utilise sur CasUsageMVP.domaine et BailleurDomaineInteret.domaine.
enum Domaine {
  FINANCES_PUBLIQUES
  CLIMAT_AFFAIRES
  PROTECTION_SOCIALE
  SANTE_NUMERIQUE
  EDUCATION
  IDENTITE_NUMERIQUE
  JUSTICE_ETAT_CIVIL
  FONCIER_CADASTRE
  AGRICULTURE_NUMERIQUE
  EMPLOI_FORMATION
  SERVICES_CITOYENS
  GOUVERNANCE_DONNEES
  CYBERSECURITE
  TRANSVERSAL
}

/// PTF Phase 2 — Type de manifestation d'un partenaire sur un cas
enum ManifestationType {
  INTERET // Intention sans engagement financier
  FINANCEMENT // Proposition de financement chiffree
}

/// PTF Phase 2 — Cycle de vie d'une manifestation
enum ManifestationStatus {
  DRAFT // Brouillon, modifiable par le partenaire
  EN_VALIDATION // Soumise, en attente de validation MCTN
  PUBLIE // Validee, publique sur le tableau de bord coordination
  REJETE // Refusee par la DU
  RETIRE // Retiree par le partenaire
}

/// PTF Phase 2 — Actions traces dans le journal d'audit dedie
enum AuditAction {
  CONSULTATION_FICHE
  CREATION_MANIFESTATION
  MODIFICATION_MANIFESTATION
  SOUMISSION_MANIFESTATION
  RETRAIT_MANIFESTATION
  VALIDATION_MANIFESTATION
  REJET_MANIFESTATION
  DEMANDE_COMPLEMENT
  CREATION_PROPOSITION
  MODIFICATION_DOMAINES_PTF
  EXPORT_DONNEES
  TELECHARGEMENT_DOCUMENT
  CONNEXION
  ACCEPTATION_CGU
}

/// Niveau de maturite d'une proposition (P8)
enum NiveauMaturite {
  ESQUISSE // Idee formulee, pas de specification technique
  PRE_CADREE // Institutions pressenties + registres listes
  PRETE_A_ADOPTER // Travail preparatoire complet
}

/// Role pressenti d'une institution sur une proposition (P8)
enum RolePressenti {
  INITIATEUR_PRESSENTI
  FOURNISSEUR_PRESSENTI
  CONSOMMATEUR_PRESSENTI
  PARTIE_PRENANTE_PRESSENTIE
}

/// Type d'avis formel donné par une partie prenante
enum FeedbackType {
  VALIDATION
  RESERVE
  REFUS_MOTIVE
  QUESTION
  CONTRE_PROPOSITION
}

/// Statut d'une consultation adressée à une partie prenante
enum ConsultationStatus {
  EN_ATTENTE
  REPONDU
  ECHU
  ANNULE
}

/// Mode d'interaction cas d'usage ↔ référentiel national
enum RegistreUsageMode {
  CONSOMME
  ALIMENTE
  CREE
}

/// Public cible d'un service guichet e-sénégal (citoyen, entreprise, mixte)
enum PublicCible {
  CITOYEN
  ENTREPRISE
  MIXTE
}

// ============================================================================
// INSTITUTIONS
// ============================================================================

model Institution {
  id        String @id @default(uuid())
  code      String @unique // Ex: DGID, DGD, ANSD
  nom       String
  ministere String

  // Contact principal
  responsableNom      String
  responsableFonction String
  responsableEmail    String @unique
  responsableTel      String

  // Relations
  users          User[]
  submissions    Submission[]
  conventionsA   Convention[]    @relation("conventionPartieA")
  conventionsB   Convention[]    @relation("conventionPartieB")
  xroadReadiness XRoadReadiness?

  // Vue 360° — relations inverses
  stakeholders      UseCaseStakeholder[]
  notificationsInst Notification[]       @relation("InstitutionNotifications")

  // Catalogue propositions (P8)
  casUsagesAdoptes CasUsageMVP[]           @relation("CasUsageAdopte")
  pressentieSur    InstitutionPressentie[]
  adoptionRequests AdoptionRequest[]

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("institutions")
}

// ============================================================================
// SOUMISSIONS QUESTIONNAIRE
// ============================================================================

model Submission {
  id String @id @default(uuid())

  // Institution
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  // Workflow
  status      SubmissionStatus @default(DRAFT)
  currentStep Int              @default(0) // 0-5

  // Section A - Gouvernance des données
  dataOwnerNom         String?
  dataOwnerFonction    String?
  dataOwnerEmail       String?
  dataOwnerTelephone   String?
  dataStewardNom       String?
  dataStewardProfil    String?
  dataStewardFonction  String?
  dataStewardEmail     String?
  dataStewardTelephone String?

  // Section B - Systèmes d'information
  applications        Application[]
  registres           Registre[]
  infrastructureItems InfrastructureItem[]

  // Infrastructure (JSON flexible - legacy)
  infrastructure Json? // { serveurs, sgbd, reseau, securite }

  // Section C - Besoins échanges
  donneesConsommer DonneeConsommer[]
  donneesFournir   DonneeFournir[]
  fluxExistants    FluxExistant[] // Legacy — conservé pour rétrocompatibilité
  casUsage         CasUsage[]
  fluxInstitutions FluxInstitution[] // Nouveau : liens vers registre CasUsageMVP

  // Framework interopérabilité
  niveauxInterop      NiveauInterop[]
  dictionnaireDonnees DictionnaireDonnee[]
  conformitePrincipes ConformitePrincipe[]
  preparationDecret   PreparationDecret[]

  // Section D - Contraintes et maturité
  contraintesJuridiques String? @db.Text
  contraintesTechniques String? @db.Text

  maturiteInfra       Int @default(3) @db.SmallInt // 1-5
  maturiteDonnees     Int @default(3) @db.SmallInt
  maturiteCompetences Int @default(3) @db.SmallInt
  maturiteGouvernance Int @default(3) @db.SmallInt

  // Section E - Auto-diagnostic
  forces     String? @db.Text
  faiblesses String? @db.Text

  // Section F - Attentes
  attentes      String? @db.Text
  contributions String? @db.Text

  // Métadonnées
  submittedAt DateTime?
  reviewedAt  DateTime?
  reviewedBy  String? // User ID

  // Import tracking
  importHash     String? // MD5 hash du fichier Word importé
  importFilename String? // Nom du fichier importé
  importedAt     DateTime? // Date d'import

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId, status])
  @@index([submittedAt])
  @@map("submissions")
}

enum SubmissionStatus {
  DRAFT // En cours de remplissage
  SUBMITTED // Soumis par l'institution
  REVIEWED // Relu par SENUM
  VALIDATED // Validé final
  ARCHIVED // Archivé
}

// ============================================================================
// APPLICATIONS ET SYSTÈMES (Section B.1)
// ============================================================================

model Application {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  nom               String
  description       String? @db.Text
  editeur           String? // Éditeur/fournisseur
  anneeInstallation Int?

  ordre Int @default(0) // Pour tri

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@map("applications")
}

// ============================================================================
// REGISTRES / BASES DE RÉFÉRENCE (Section B.2)
// ============================================================================

model Registre {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  nom         String
  description String? @db.Text
  volumetrie  String? // Ex: "5M entités", "250K entreprises"

  // E.6 — Indicateurs de qualité
  tauxCompletude      Int? // 0-100
  tauxDoublons        Int? // 0-100
  dernierNettoyage    DateTime?
  planQualiteExiste   Boolean   @default(false)
  processusCorrection String?   @db.Text
  frequenceAudit      String? // Jamais, Annuel, Semestriel, Trimestriel, Mensuel

  ordre Int @default(0)

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@map("registres")
}

// ============================================================================
// BESOINS EN DONNÉES (Section C)
// ============================================================================

// C.1 - Données à CONSOMMER
model DonneeConsommer {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  donnee   String // Type de donnée recherchée
  source   String // Administration source
  usage    String? @db.Text // Usage prévu
  priorite Int     @default(3) @db.SmallInt // 1-5

  ordre Int @default(0)

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@map("donnees_consommer")
}

// C.2 - Données à FOURNIR
model DonneeFournir {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  donnee        String // Type de donnée
  destinataires String? // Qui pourrait consommer
  frequence     String? // Fréquence de MAJ
  format        String? // Format disponible (API, fichier, etc.)

  ordre Int @default(0)

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@map("donnees_fournir")
}

// C.3 - Flux existants
model FluxExistant {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  source      String
  destination String
  donnee      String?
  mode        String? // API REST, fichier, email, etc.
  frequence   String?

  ordre Int @default(0)

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@map("flux_existants")
}

// C.4 - Cas d'usage prioritaires
model CasUsage {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  titre       String
  description String  @db.Text
  acteurs     String? @db.Text
  priorite    Int     @default(3) @db.SmallInt

  // P.6 — Lien avec cas d'usage MVP
  casUsageMVPId String?
  casUsageMVP   CasUsageMVP? @relation(fields: [casUsageMVPId], references: [id])

  ordre Int @default(0)

  createdAt DateTime @default(now())

  @@index([submissionId, priorite])
  @@map("cas_usage")
}

// ============================================================================
// F.1 — DIAGNOSTIC 5 NIVEAUX D'INTEROPÉRABILITÉ
// ============================================================================

model NiveauInterop {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  niveau   String // POLITIQUE, JURIDIQUE, ORGANISATIONNEL, SEMANTIQUE, TECHNIQUE
  question String
  reponse  String // Oui, Non, En cours, Partiellement, etc.
  details  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, niveau, question])
  @@index([submissionId])
  @@map("niveaux_interop")
}

// ============================================================================
// F.3 — CONFORMITÉ AUX 13 PRINCIPES
// ============================================================================

model ConformitePrincipe {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  principeNumero Int // 1-13
  categorie      String // A, B, C, D
  score          Int     @default(1) @db.SmallInt // 1-5
  commentaire    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, principeNumero])
  @@index([submissionId])
  @@map("conformite_principes")
}

// ============================================================================
// F.4 — DICTIONNAIRE DE DONNÉES SÉMANTIQUE
// ============================================================================

model DictionnaireDonnee {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  nomChamp           String
  definition         String? @db.Text
  formatTechnique    String? // Texte, Numérique, Date, Booléen, Code, Montant, Autre
  taille             String?
  referentielOrigine String? // Institution source de vérité
  nomenclature       String?
  identifiantPivot   Boolean @default(false)
  frequenceMAJ       String?
  sensibilite        String? // Public, Usage interne, Confidentiel, Secret
  observations       String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@map("dictionnaire_donnees")
}

// ============================================================================
// F.5 — PRÉPARATION AU DÉCRET INTEROPÉRABILITÉ
// ============================================================================

model PreparationDecret {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  chapitre String // CHAPITRE_2, CHAPITRE_3, CHAPITRE_4
  question String
  reponse  String
  details  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, chapitre, question])
  @@index([submissionId])
  @@map("preparation_decret")
}

// ============================================================================
// INFRASTRUCTURE TECHNIQUE (Section B.3)
// ============================================================================

model InfrastructureItem {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  domain         String // EQUIPEMENTS_SYSTEME, RESEAU_CONNECTIVITE, API_SERVICES, SECURITE_CERTIFICATS, ENERGIE_CONTINUITE, RESSOURCES_HUMAINES, LICENCES_LOGICIELS
  element        String // Ex: "Datacenter", "Serveurs en production"
  disponibilite  Boolean? // Oui/Non/null
  qualifications String? // Détails texte libre
  observations   String? // Spécifications / observations

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, domain, element])
  @@index([submissionId])
  @@map("infrastructure_items")
}

// ============================================================================
// E.4 — CONVENTIONS D'ÉCHANGE
// ============================================================================

model Convention {
  id             String      @id @default(uuid())
  institutionAId String
  institutionA   Institution @relation("conventionPartieA", fields: [institutionAId], references: [id])
  institutionBId String
  institutionB   Institution @relation("conventionPartieB", fields: [institutionBId], references: [id])

  objet         String
  donneesVisees String?          @db.Text
  statut        ConventionStatus @default(NON_INITIEE)

  dateInitiation DateTime?
  dateRedaction  DateTime?
  dateSignatureA DateTime?
  dateSignatureB DateTime?
  dateActivation DateTime?
  dateExpiration DateTime?

  referenceDocument String?
  lienDocument      String? // URL vers le document partagé (SharePoint, Drive, etc.)
  observations      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Cas d'usage lies (P9) — un cas d'usage technique peut referencer une convention
  casUsagesLies CasUsageMVP[] @relation("CasUsageConvention")

  @@index([institutionAId])
  @@index([institutionBId])
  @@map("conventions")
}

enum ConventionStatus {
  NON_INITIEE
  EN_COURS_REDACTION
  EN_ATTENTE_SIGNATURE_A
  EN_ATTENTE_SIGNATURE_B
  SIGNEE
  ACTIVE
  EXPIREE
  SUSPENDUE
}

// ============================================================================
// E.5 — PIPELINE X-ROAD
// ============================================================================

model XRoadReadiness {
  id            String      @id @default(uuid())
  institutionId String      @unique
  institution   Institution @relation(fields: [institutionId], references: [id])

  serveurDedie          JalonStatus @default(NON_DEMARRE)
  serveurDedieDate      DateTime?
  connectiviteReseau    JalonStatus @default(NON_DEMARRE)
  connectiviteDate      DateTime?
  certificatsSSL        JalonStatus @default(NON_DEMARRE)
  certificatsDate       DateTime?
  securityServerInstall JalonStatus @default(NON_DEMARRE)
  securityServerDate    DateTime?
  premierServicePublie  JalonStatus @default(NON_DEMARRE)
  premierServiceDate    DateTime?
  premierEchangeReussi  JalonStatus @default(NON_DEMARRE)
  premierEchangeDate    DateTime?

  observations  String? @db.Text
  blocage       String?
  prochainJalon String?

  // Hébergement du Security Server
  hebergement         HebergementType  @default(SENUM_CENTRALISE)
  hebergementCible    HebergementType?
  dateMigrationPrevue DateTime?
  prerequisMigration  String?          @db.Text

  // Maturité API
  disposeAPI      Boolean @default(false)
  maturiteAPI     String?
  systemeSource   String?
  protocoleAPI    String?
  observationsAPI String? @db.Text

  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("xroad_readiness")
}

enum HebergementType {
  SENUM_CENTRALISE
  HEBERGEMENT_PROPRE
  MIXTE
}

enum JalonStatus {
  NON_DEMARRE
  EN_COURS
  BLOQUE
  TERMINE
}

// ============================================================================
// RAPPORTS ET EXPORTS
// ============================================================================

model Report {
  id     String     @id @default(uuid())
  type   ReportType
  format String // PDF, CSV, XLSX, JSON

  // Fichier généré
  filename String
  filepath String?
  filesize Int? // bytes

  // Métadonnées
  generatedBy String? // User ID
  parameters  Json? // Paramètres du rapport

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@map("reports")
}

// ============================================================================
// CATALOGUE DPI — BUILDING BLOCKS
// ============================================================================

model BuildingBlock {
  id          String    @id @default(uuid())
  code        String    @unique
  nom         String
  description String    @db.Text
  couche      CoucheDPI

  statut          StatutBB @default(NON_DEMARRE)
  operateur       String?
  compatibleXRoad Boolean  @default(false)

  urlDocumentation String?
  technologie      String?
  dateDeploiement  DateTime?
  observations     String?   @db.Text

  ordre Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([couche])
  @@map("building_blocks")
}

enum CoucheDPI {
  FONDATION
  INTEGRATION
  INFRASTRUCTURE
  APPLICATION
}

enum StatutBB {
  OPERATIONNEL
  EN_DEPLOIEMENT
  PLANIFIE
  NON_DEMARRE
}

// ============================================================================
// REGISTRES NATIONAUX (référentiel autoritaire)
// ============================================================================

model RegistreNational {
  id          String  @id @default(uuid())
  code        String  @unique
  nom         String
  description String? @db.Text
  domaine     String

  institutionCode String
  institutionNom  String

  systemeSource     String?
  identifiantPivot  String?
  formatIdentifiant String?
  volumeEstime      String?

  statutNumerisation String?
  statutEjokkoo      String?
  disposeAPI         Boolean @default(false)
  protocoleAPI       String?

  baseLegale    String? @db.Text
  consommateurs String? @db.Text
  observations  String? @db.Text

  tauxCompletude Int?
  tauxDoublons   Int?

  // Vue 360° — relation inverse
  casUsagesAssocies CasUsageRegistre[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domaine])
  @@map("registres_nationaux")
}

enum ReportType {
  COMPILATION // Compilation globale
  MATRICE_FLUX // Matrice fournisseur/consommateur
  STATISTIQUES // Stats générales
  EXPORT_INSTITUTION // Export données d'une institution
  EXPORT_COMPLET // Export toutes données
}

// ============================================================================
// P.1 — PARTENAIRES TECHNIQUES ET FINANCIERS (PTF)
// ============================================================================

model PTF {
  id           String      @id @default(uuid())
  code         String      @unique
  nom          String
  acronyme     String
  type         PTFType
  pays         String?
  contactNom   String?
  contactEmail String?
  contactTel   String?
  programmes   Programme[]
  users        User[] // Comptes BAILLEUR rattachés à ce PTF (phase 1)

  // PTF Phase 2
  domainesInteret BailleurDomaineInteret[]
  manifestations  ManifestationInteret[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ptf")
}

// ============================================================================
// PTF Phase 2 — Domaines d'interet declares par un PTF
// ============================================================================

model BailleurDomaineInteret {
  id          String   @id @default(cuid())
  ptfId       String
  ptf         PTF      @relation(fields: [ptfId], references: [id], onDelete: Cascade)
  domaine     Domaine
  declaresPar String? // userId admin ayant declare le rattachement
  createdAt   DateTime @default(now())

  @@unique([ptfId, domaine])
  @@index([ptfId])
  @@index([domaine])
  @@map("bailleur_domaine_interet")
}

// ============================================================================
// PTF Phase 2 — Manifestations d'interet ou de financement par un PTF
// ============================================================================

model ManifestationInteret {
  id String @id @default(cuid())

  casUsageId String
  casUsage   CasUsageMVP @relation(fields: [casUsageId], references: [id])

  ptfId String
  ptf   PTF    @relation(fields: [ptfId], references: [id])

  userId String
  user   User   @relation("ManifestationCreator", fields: [userId], references: [id])

  type   ManifestationType
  statut ManifestationStatus @default(DRAFT)

  commentaire         String? @db.Text
  montantEstime       Float?
  devise              String? // EUR, USD, XOF, ...
  instrumentFinancier String? // DON, PRET_CONCESSIONNEL, ASSISTANCE_TECHNIQUE, ...

  valideParUserId String?
  valideParUser   User?     @relation("ValidateurManifestation", fields: [valideParUserId], references: [id])
  dateValidation  DateTime?
  motifRejet      String?   @db.Text

  // PTF Phase 2 — Articulation amont/aval
  // Une manifestation PUBLIE et de type FINANCEMENT peut générer un (ou plusieurs)
  // Financement(s) côté DU. Une retentative après REJETE peut produire plusieurs
  // Financements dans le temps — d'où la cardinalité 1:N (et non 1:1).
  financementsGeneres Financement[] @relation("ManifestationVersFinancement")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([casUsageId])
  @@index([ptfId])
  @@index([statut])
  @@map("manifestation_interet")
}

// ============================================================================
// PTF Phase 2 — Journal d'audit dedie au module PTF
// ============================================================================

model JournalAuditPtf {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("AuditUserPtf", fields: [userId], references: [id])
  action    AuditAction
  objetType String? // "manifestation", "cas_usage", "ptf", "user", ...
  objetId   String?
  details   Json? // Diff avant/apres pour les modifications
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("journal_audit_ptf")
}

enum PTFType {
  BILATERAL
  MULTILATERAL
  FONDATION
  ETAT
  PRIVE
}

model Programme {
  id                  String          @id @default(uuid())
  ptfId               String
  ptf                 PTF             @relation(fields: [ptfId], references: [id])
  code                String          @unique
  nom                 String
  description         String?         @db.Text
  consortium          String?
  partenaireTechnique String?
  montantTotal        Float?
  devise              String          @default("FCFA")
  montantDecaisse     Float?
  dateDebut           DateTime?
  dateFin             DateTime?
  statut              ProgrammeStatus @default(ACTIF)
  composantsDPI       String?
  financements        Financement[]
  expertises          Expertise[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([ptfId])
  @@map("programmes")
}

enum ProgrammeStatus {
  EN_PREPARATION
  ACTIF
  EN_CLOTURE
  CLOTURE
  SUSPENDU
}

model Expertise {
  id          String    @id @default(uuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id])
  nom         String
  profil      String
  role        String?
  dateDebut   DateTime?
  dateFin     DateTime?
  actif       Boolean   @default(true)
  prestataire String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([programmeId])
  @@map("expertises")
}

// ============================================================================
// PHASES MVP & CAS D'USAGE
// ============================================================================

model PhaseMVP {
  id                 String        @id @default(uuid())
  code               String        @unique
  nom                String
  description        String?       @db.Text
  dateDebutPrevue    DateTime?
  dateFinPrevue      DateTime?
  dateDebutEffective DateTime?
  dateFinEffective   DateTime?
  statut             PhaseStatus   @default(PLANIFIE)
  livrablesCles      String?       @db.Text
  casUsageMVP        CasUsageMVP[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("phases_mvp")
}

enum PhaseStatus {
  PLANIFIE
  EN_COURS
  TERMINE
  REPORTE
}

model CasUsageMVP {
  id                    String               @id @default(uuid())
  code                  String               @unique
  ancienCode            String? // Ancien code avant harmonisation PINS-CU-XXX
  codeHistorique        String?              @db.Text // N2 — Migration nomenclature : conserve l'origine (ex: "MVP1-CU-02, PINS-CU-011, UC-GIZ-FIN-01")
  titre                 String
  description           String?              @db.Text
  institutionSourceCode String?
  institutionCibleCode  String?
  autresInstitutions    String?
  donneesEchangees      String?
  donneesEntree         String?                 @db.Text // Contrat : données d'entrée (clé d'appel)
  donneesSortie         String?                 @db.Text // Contrat : données de sortie (réponse)
  donneesLecture        String?                 @db.Text // Contrat : données lues dans le registre producteur
  registresConcernes    String?
  axePrioritaire        String?
  impact                ImpactLevel          @default(MOYEN)
  complexite            ImpactLevel          @default(MOYEN)
  phaseMVPId            String?
  phaseMVP              PhaseMVP?            @relation(fields: [phaseMVPId], references: [id])
  statutImpl            StatutImplementation @default(IDENTIFIE)
  prerequis             String?              @db.Text
  conventionRequise     Boolean              @default(true)
  conventionSignee      Boolean              @default(false)
  financements          Financement[]
  declarationsInst      CasUsage[]
  fluxInstitutions      FluxInstitution[]
  accompagnementsAMO    AccompagnementAMO[]
  dateIdentification    DateTime?
  dateLancement         DateTime?
  dateMiseEnProd        DateTime?
  notes                 String?              @db.Text // Notes libres admin
  timeline              Json? // Historique événements [{date, event, auteur}]
  observations          String?              @db.Text

  // Vue 360° — champs et relations
  statutVueSection  UseCaseStatus          @default(DECLARE)
  resumeMetier      String?                @db.Text // Résumé métier 2-3 lignes
  baseLegale        String?                @db.Text // Base légale invoquée
  stakeholders360   UseCaseStakeholder[]
  statusHistory     UseCaseStatusHistory[]
  registresAssocies CasUsageRegistre[]

  // Catalogue des propositions (P8)
  sourceProposition       SourceProposition?
  sourceDetail            String?                 @db.Text // Details de la source, visible DETAILED/FULL uniquement
  niveauMaturite          NiveauMaturite? // null pour CU deja adoptes (statut != PROPOSE)
  dateAdoption            DateTime?
  adopteParInstitutionId  String?
  adopteParInstitution    Institution?            @relation("CasUsageAdopte", fields: [adopteParInstitutionId], references: [id])
  adopteParUserId         String?
  adopteParUser           User?                   @relation("CasUsageAdoptePar", fields: [adopteParUserId], references: [id])
  institutionsPressenties InstitutionPressentie[]
  fusionneVersId          String? // Si statut=FUSIONNE : pointeur vers CU cible
  fusionneVers            CasUsageMVP?            @relation("FusionCU", fields: [fusionneVersId], references: [id])
  fusionnesDepuis         CasUsageMVP[]           @relation("FusionCU")
  adoptionRequests        AdoptionRequest[]

  // Typologie (P9)
  typologie              TypologieCasUsage // PAS de défaut : doit être explicitement positionné à la création
  reclassementsTypologie Json? // [{from, to, motif, auteurUserId, auteurNom, date}]

  // Liaison conventions (P9)
  conventionLieeId String?
  conventionLiee   Convention? @relation("CasUsageConvention", fields: [conventionLieeId], references: [id])

  // Relations de service metier <-> technique (P9)
  relationsMetier    RelationCasUsage[] @relation("RelationMetier")
  relationsTechnique RelationCasUsage[] @relation("RelationTechnique")

  // PTF Phase 2 — Eligibilite appui partenaire + domaine normalise
  aFinancer Boolean  @default(false)
  domaine   Domaine?

  // PTF Phase 2 — Relations vers les manifestations partenaires
  manifestations ManifestationInteret[]

  // New Deal Technologique — Projets nationaux associés
  casUsageProjets CasUsageProjet[]

  // Liaison vers les services guichet e-sénégal (frontière backbone/front)
  liaisonsGuichet LiaisonGuichet[]

  // Faisabilité (atelier use cases potentiels)
  faisabilite FaisabiliteCas?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseMVPId])
  @@index([axePrioritaire])
  @@index([statutImpl])
  @@index([statutVueSection])
  @@index([typologie])
  @@index([adopteParInstitutionId])
  @@index([aFinancer])
  @@index([domaine])
  @@map("cas_usage_mvp")
}

// ============================================================================
// FAISABILITÉ — Évaluation brute des propositions (atelier use cases potentiels)
// ============================================================================

model FaisabiliteCas {
  id        String @id @default(uuid())
  casUsageId String @unique
  casUsage   CasUsageMVP @relation(fields: [casUsageId], references: [id], onDelete: Cascade)

  // Juridique
  partageLegalementAutorise     Boolean // Q1+: Le partage est-il légalement autorisé ?
  contraintesBloquantesProtection Boolean // Q1-: Existe-t-il des contraintes bloquantes ?
  // Institutionnelle
  institutionsAptesAPartager    Boolean // Q2+: Les institutions sont-elles aptes à partager ?
  obstaclesCoordination         Boolean // Q2-: Existe-t-il des obstacles à la coordination ?
  // Gouvernance
  proprieteDonneesDefinie       Boolean // Q3+: La propriété des données est-elle définie ?
  incoherencesNormes            Boolean // Q3-: Existe-t-il des incohérences de normes ?
  // Technique
  systemesPrennentEnCharge      Boolean // Q4+: Les systèmes peuvent-ils prendre en charge ?
  infraDisponible               Boolean // Q4+: L'infrastructure est-elle disponible ?

  source  String @default("Atelier - TABLEAU_DES_USE_CASE_POTENTIELS.xlsx")
  notes   String? @db.Text // Points à confirmer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faisabilite_cas")
}

enum ImpactLevel {
  FAIBLE
  MOYEN
  ELEVE
  CRITIQUE
}

enum StatutImplementation {
  IDENTIFIE
  PRIORISE
  EN_PREPARATION
  EN_DEVELOPPEMENT
  EN_TEST
  EN_PRODUCTION
  SUSPENDU
}

// ============================================================================
// CATALOGUE DES PROPOSITIONS (P8) ET TYPOLOGIE (P9)
// ============================================================================

/// Institution pressentie pour une proposition (indicative, pas engagee).
/// Distincte de UseCaseStakeholder (qui represente un stakeholder designe
/// apres adoption, avec engagement institutionnel formel).
model InstitutionPressentie {
  id            String        @id @default(cuid())
  casUsageId    String
  casUsage      CasUsageMVP   @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution   @relation(fields: [institutionId], references: [id])
  rolePressenti RolePressenti
  commentaire   String?       @db.Text
  createdAt     DateTime      @default(now())

  @@unique([casUsageId, institutionId])
  @@index([institutionId])
  @@map("institution_pressentie")
}

/// Relation N-N entre un cas d'usage METIER et les cas d'usage TECHNIQUES
/// qu'il mobilise. Contrainte metier verifiee en backend :
/// - casUsageMetier.typologie DOIT etre METIER
/// - casUsageTechnique.typologie DOIT etre TECHNIQUE
model RelationCasUsage {
  id                  String      @id @default(cuid())
  casUsageMetierId    String
  casUsageMetier      CasUsageMVP @relation("RelationMetier", fields: [casUsageMetierId], references: [id], onDelete: Cascade)
  casUsageTechniqueId String
  casUsageTechnique   CasUsageMVP @relation("RelationTechnique", fields: [casUsageTechniqueId], references: [id], onDelete: Cascade)
  ordre               Int? // Position dans le parcours si sequence
  obligatoire         Boolean     @default(true)
  commentaire         String?     @db.Text
  createdAt           DateTime    @default(now())
  createdBy           String
  createdByUser       User        @relation("RelationCasUsageCree", fields: [createdBy], references: [id])

  @@unique([casUsageMetierId, casUsageTechniqueId])
  @@index([casUsageMetierId])
  @@index([casUsageTechniqueId])
  @@map("relation_cas_usage")
}

/// Demande d'adoption par une institution non pressentie, necessitant une
/// validation explicite de la DU (principe de gouvernance P8).
enum AdoptionRequestStatus {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

model AdoptionRequest {
  id                      String                @id @default(cuid())
  casUsageId              String
  casUsage                CasUsageMVP           @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  institutionDemandeuseId String
  institutionDemandeuse   Institution           @relation(fields: [institutionDemandeuseId], references: [id])
  userDemandeurId         String
  userDemandeur           User                  @relation("AdoptionRequestDemandeur", fields: [userDemandeurId], references: [id])
  motif                   String                @db.Text // min 50 car cote applicatif
  status                  AdoptionRequestStatus @default(EN_ATTENTE)
  ajustements             Json? // ajustements proposes sur pressenties/registres
  dateDemande             DateTime              @default(now())
  dateTraitement          DateTime?
  userValideurId          String?
  userValideur            User?                 @relation("AdoptionRequestValideur", fields: [userValideurId], references: [id])
  motifTraitement         String?               @db.Text

  @@index([casUsageId])
  @@index([institutionDemandeuseId])
  @@index([status])
  @@map("adoption_request")
}

model Financement {
  id              String            @id @default(uuid())
  casUsageMVPId   String
  casUsageMVP     CasUsageMVP       @relation(fields: [casUsageMVPId], references: [id], onDelete: Cascade)
  programmeId     String
  programme       Programme         @relation(fields: [programmeId], references: [id])
  montantAlloue   Float?
  typeFinancement String?
  statut          FinancementStatus @default(DEMANDE)
  dateDemande     DateTime?
  dateAccord      DateTime?
  observations    String?

  // PTF Phase 2 — Articulation amont/aval
  // Un Financement peut être issu de la validation MCTN d'une ManifestationInteret
  // de type FINANCEMENT (option de conversion offerte à l'admin lors du validate).
  // Champ nullable : un Financement peut aussi être saisi directement (engagement
  // hérité d'avant le module PTF, ou intégré sans passer par le workflow partenaire).
  manifestationOrigineId String?
  manifestationOrigine   ManifestationInteret? @relation("ManifestationVersFinancement", fields: [manifestationOrigineId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([casUsageMVPId, programmeId])
  @@index([casUsageMVPId])
  @@index([programmeId])
  @@index([manifestationOrigineId])
  @@map("financements")
}

enum FinancementStatus {
  IDENTIFIE
  DEMANDE
  EN_NEGOCIATION
  ACCORDE
  EN_COURS
  CLOTURE
  REFUSE
}

// ============================================================================
// FLUX × INSTITUTION (table de liaison registre unique)
// ============================================================================

model FluxInstitution {
  id            String      @id @default(uuid())
  submissionId  String
  submission    Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  casUsageMVPId String
  casUsageMVP   CasUsageMVP @relation(fields: [casUsageMVPId], references: [id])

  roleInstitution  String // FOURNISSEUR, CONSOMMATEUR, BIDIRECTIONNEL
  modeActuel       String?
  frequence        String?
  conventionSignee Boolean @default(false)
  volumeEstime     String?
  observations     String? @db.Text
  priorite         Int     @default(3) @db.SmallInt

  // Qualification par l'institution
  justificationMetier String?      @db.Text
  problemeActuel      String?      @db.Text
  beneficeAttendu     String?      @db.Text
  impactEstime        ImpactLevel?
  urgence             Int?         @db.SmallInt // 1-5
  pretTechniquement   String? // Oui API existante, Oui API à développer, Partiellement, Non

  // Qualification par le SENUM
  qualifie            Boolean      @default(false)
  dateQualification   DateTime?
  qualifiePar         String?
  noteQualification   String?      @db.Text
  impactValide        ImpactLevel?
  complexiteTechnique ImpactLevel?
  scoreTotal          Int?

  // Prérequis identifiés
  prerequisConvention     Boolean @default(false)
  prerequisSecurityServer Boolean @default(false)
  prerequisAPI            Boolean @default(false)
  prerequisNettoyage      Boolean @default(false)
  prerequisAutre          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, casUsageMVPId])
  @@index([casUsageMVPId])
  @@index([qualifie])
  @@map("flux_institutions")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  userEmail     String
  userRole      String
  ipAddress     String?
  userAgent     String?
  action        String
  resource      String
  resourceId    String?
  resourceLabel String?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserSession {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String    @unique
  ipAddress      String?
  userAgent      String?
  loginAt        DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime
  isActive       Boolean   @default(true)
  logoutAt       DateTime?

  @@index([userId])
  @@index([isActive])
  @@map("user_sessions")
}

// ============================================================================
// DEMANDES D'INTEROPÉRABILITÉ
// ============================================================================

model DemandeInterop {
  id                 String    @id @default(uuid())
  institutionId      String
  demandeurNom       String
  demandeurEmail     String
  type               String // ACCES_DONNEES, CONVENTION, CONNEXION_PINS, ACCOMPAGNEMENT, SIGNALEMENT
  titre              String
  description        String    @db.Text
  institutionCibleId String?
  donneesVisees      String?   @db.Text
  justification      String?   @db.Text
  frequenceSouhaitee String?
  urgence            String    @default("NORMALE") // FAIBLE, NORMALE, HAUTE, CRITIQUE
  statut             String    @default("SOUMISE") // SOUMISE, EN_COURS_TRAITEMENT, EN_ATTENTE_PARTENAIRE, RESOLUE, REJETEE
  reponse            String?   @db.Text
  respondantNom      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  traiteeAt          DateTime?

  @@index([institutionId])
  @@index([statut])
  @@map("demandes_interop")
}

// ============================================================================
// VUE 360° — NOUVEAUX MODÈLES
// ============================================================================

/// Partie prenante formellement désignée d'un cas d'usage
model UseCaseStakeholder {
  id               String            @id @default(cuid())
  casUsageId       String
  institutionId    String
  role             UseCaseRole
  autoSaisine      Boolean           @default(false)
  motifAutoSaisine String?           @db.Text
  typeConcernement TypeConcernement?
  dateAjout        DateTime          @default(now())
  ajoutePar        String?
  actif            Boolean           @default(true)
  dateRetrait      DateTime?
  motifRetrait     String?           @db.Text
  retireParUserId  String?
  evictionParDU    Boolean           @default(false)
  evictionMotif    String?           @db.Text

  casUsage      CasUsageMVP           @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  institution   Institution           @relation(fields: [institutionId], references: [id])
  ajouteParUser User?                 @relation("StakeholderAjoute", fields: [ajoutePar], references: [id])
  retireParUser User?                 @relation("StakeholderRetire", fields: [retireParUserId], references: [id])
  consultations UseCaseConsultation[]
  feedbacks     UseCaseFeedback[]

  @@unique([casUsageId, institutionId, role])
  @@index([institutionId, role, actif])
  @@index([casUsageId, actif])
  @@map("use_case_stakeholder")
}

enum TypeConcernement {
  DONNEES_DETENUES
  PROCESSUS_IMPACTE
  GOUVERNANCE_TRANSVERSE
  AUTRE
}

/// Consultation : demande d'avis adressée à une partie prenante
model UseCaseConsultation {
  id              String             @id @default(cuid())
  stakeholderId   String
  dateDemande     DateTime           @default(now())
  dateEcheance    DateTime
  status          ConsultationStatus @default(EN_ATTENTE)
  relances        Int                @default(0)
  derniereRelance DateTime?
  ouvertePar      String
  motifSollicit   String?            @db.Text

  stakeholder   UseCaseStakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  ouvertParUser User               @relation("ConsultationOuvertePar", fields: [ouvertePar], references: [id])
  feedbacks     UseCaseFeedback[]

  @@index([stakeholderId])
  @@index([status, dateEcheance])
  @@map("use_case_consultation")
}

/// Avis formel donné par une institution en réponse à une consultation
model UseCaseFeedback {
  id                   String       @id @default(cuid())
  consultationId       String?
  stakeholderId        String
  type                 FeedbackType
  motivation           String       @db.Text
  piecesJointes        Json?
  auteurUserId         String
  auteurNom            String
  auteurFonction       String?
  auteurInstitutionNom String
  dateAvis             DateTime     @default(now())
  amendeDe             String?

  consultation     UseCaseConsultation? @relation(fields: [consultationId], references: [id])
  stakeholder      UseCaseStakeholder   @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  auteur           User                 @relation("FeedbackAuteur", fields: [auteurUserId], references: [id])
  amendements      UseCaseFeedback[]    @relation("FeedbackAmendement")
  amendeDeFeedback UseCaseFeedback?     @relation("FeedbackAmendement", fields: [amendeDe], references: [id])

  @@index([stakeholderId, dateAvis])
  @@index([auteurUserId])
  @@index([consultationId])
  @@map("use_case_feedback")
}

/// Journal inaltérable des transitions d'état d'un cas d'usage
model UseCaseStatusHistory {
  id                String         @id @default(cuid())
  casUsageId        String
  statusFrom        UseCaseStatus?
  statusTo          UseCaseStatus
  motif             String?        @db.Text
  auteurUserId      String
  auteurNom         String
  auteurInstitution String
  dateTransition    DateTime       @default(now())
  pieceJustif       String?

  casUsage CasUsageMVP @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  auteur   User        @relation("StatusHistoryAuteur", fields: [auteurUserId], references: [id])

  @@index([casUsageId, dateTransition])
  @@index([auteurUserId])
  @@map("use_case_status_history")
}

/// Notification in-app Vue 360°
model Notification {
  id            String    @id @default(cuid())
  userId        String
  institutionId String?
  type          String // CONSULTATION_OUVERTE | AVIS_RECU | RELANCE | ARBITRAGE | TRANSITION
  titre         String
  message       String    @db.Text
  lienUrl       String?
  refType       String?
  refId         String?
  lu            Boolean   @default(false)
  dateLu        DateTime?
  dateCreation  DateTime  @default(now())

  user        User         @relation("UserNotifications", fields: [userId], references: [id])
  institution Institution? @relation("InstitutionNotifications", fields: [institutionId], references: [id])

  @@index([userId, lu, dateCreation])
  @@index([institutionId, dateCreation])
  @@map("notification")
}

/// Liaison enrichie entre un cas d'usage et un référentiel national
model CasUsageRegistre {
  id              String            @id @default(cuid())
  casUsageId      String
  registreId      String
  mode            RegistreUsageMode
  champsConcernes Json?
  commentaire     String?           @db.Text
  volumetrieEst   String?
  criticite       String?
  dateAjout       DateTime          @default(now())
  ajoutePar       String?

  casUsage      CasUsageMVP      @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  registre      RegistreNational @relation(fields: [registreId], references: [id])
  ajouteParUser User?            @relation("RegistreUsageAjoute", fields: [ajoutePar], references: [id])

  @@unique([casUsageId, registreId, mode])
  @@index([registreId, mode])
  @@index([casUsageId])
  @@map("cas_usage_registre")
}

// ============================================================================
// DOCUMENTS DE RÉFÉRENCE (espace documentaire)
// ============================================================================

// ============================================================================
// NEW DEAL TECHNOLOGIQUE — PROGRAMMES PRIORITAIRES ET PROJETS NATIONAUX
// ============================================================================

model ProgrammePrioritaire {
  id        String            @id @default(uuid())
  code      String            @unique // PR-P01 à PR-P12
  nom       String
  domaine   String?           @db.Text
  finalite  String?           @db.Text
  projets   ProjetNational[]

  @@map("programme_prioritaire")
}

model ProjetNational {
  id                     String               @id @default(uuid())
  code                   String               @unique // PRJ_1.1 à PRJ_12.3
  nom                    String
  programmePrioritaireId String
  programmePrioritaire   ProgrammePrioritaire @relation(fields: [programmePrioritaireId], references: [id])
  budgetEstimatif        Float?               // milliards FCFA
  finalite               String?              @db.Text
  casUsageProjets        CasUsageProjet[]

  @@index([programmePrioritaireId])
  @@map("projet_national")
}

model CasUsageProjet {
  id               String         @id @default(uuid())
  casUsageMVPId    String
  projetNationalId String
  casUsageMVP      CasUsageMVP    @relation(fields: [casUsageMVPId], references: [id], onDelete: Cascade)
  projetNational   ProjetNational @relation(fields: [projetNationalId], references: [id], onDelete: Cascade)

  @@unique([casUsageMVPId, projetNationalId])
  @@map("cas_usage_projet")
}

model DocumentReference {
  id              String   @id @default(uuid())
  titre           String
  description     String?  @db.Text
  categorie       String // juridique, technique, guide, modele
  fichierNom      String // nom du fichier original
  fichierPath     String // chemin sur le serveur
  tailleMo        Float?
  datePublication DateTime @default(now())
  actif           Boolean  @default(true)
  uploadePar      String? // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categorie])
  @@map("documents_reference")
}

// ============================================================================
// LIAISON GUICHET e-sénégal — Frontière backbone/front
// ============================================================================
// Les démarches du guichet citoyen (e-sénégal / TELEDAC) sont matérialisées par
// une entité séparée ServiceGuichet, distincte de CasUsageMVP : pas de
// pollution des compteurs métier/technique du catalogue, et publicCible /
// statutEsenegal sont des propriétés intrinsèques du service guichet (pas de
// la liaison). LiaisonGuichet est une table de liaison N:N classique entre
// CasUsageMVP (backbone interop) et ServiceGuichet (front e-sénégal), sur le
// même pattern que CasUsageRegistre : mode/dateAjout/ajoutePar (PAS
// createdAt/updatedAt).

model ServiceGuichet {
  id                String           @id @default(uuid())
  code              String           @unique // PINS-GUICHET-NNN
  intitule          String
  evenementDeVie    String?
  secteur           String?
  publicCible       PublicCible?
  statutEsenegal    String? // Statut TELEDAC : en ligne / pas en ligne / Nekkal / etc.
  ministere         String?
  pointFocalSiTiers String?
  besoinSiTiers     String?
  priorisationJson  Json? // Scores hétérogènes des deux feuilles du séminaire
  mode              String?
  dateAjout         DateTime         @default(now())
  ajoutePar         String?
  liaisons          LiaisonGuichet[]

  @@index([secteur])
  @@map("service_guichet")
}

model LiaisonGuichet {
  id               String         @id @default(uuid())
  casUsageId       String
  serviceGuichetId String
  casUsage         CasUsageMVP    @relation(fields: [casUsageId], references: [id], onDelete: Cascade)
  serviceGuichet   ServiceGuichet @relation(fields: [serviceGuichetId], references: [id], onDelete: Cascade)
  note             String?
  mode             String?
  dateAjout        DateTime       @default(now())
  ajoutePar        String?

  @@unique([casUsageId, serviceGuichetId])
  @@index([serviceGuichetId])
  @@map("liaison_guichet")
}
