# ============================================================================
# e-jokkoo — Configuration Production
# Copier en .env.production et remplir les valeurs
# ============================================================================

# PostgreSQL
POSTGRES_USER=ejokkoo
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_64_caracteres
POSTGRES_DB=questionnaire_interop

# JWT (générer avec: openssl rand -hex 64)
JWT_SECRET=CHANGEZ_MOI_secret_jwt_64_caracteres_aleatoires

# Application
APP_PORT=80
CORS_ORIGIN=http://192.168.40.128
VITE_API_URL=

# pgAdmin (optionnel, activer avec: docker compose --profile tools up -d)
PGADMIN_EMAIL=admin@senum.sn
PGADMIN_PASSWORD=CHANGEZ_MOI_admin_pgadmin
